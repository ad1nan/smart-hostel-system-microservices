# Copy this file to .env and fill in real values.
# Never commit .env — it is in .gitignore.

# Required by auth service and api-gateway (JWT signing)
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars

# MongoDB connection — same for all services
MONGO_URI=mongodb://mongo:27017/hostelDB

# MQTT broker — used by devices and analytics
# For dev: mqtt://mqtt:1883
# For TLS-enabled broker: mqtts://mqtt:8883
MQTT_URL=mqtt://mqtt:1883

MQTT_USER=hostel_ingest
MQTT_PASS=replace-with-strong-random-password

ALLOWED_ORIGINS=http://localhost:3000
